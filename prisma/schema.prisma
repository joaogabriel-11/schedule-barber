// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  CONCLUIDO
  CANCELADO
  NO_SHOW
}

enum UserRole {
  BARBEIRO
  ADMIN
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  nome      String
  senha     String
  role      UserRole @default(BARBEIRO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agendamentos Agendamento[]
  configuracao Configuracao?
  tokensRecuperacao TokenRecuperacao[]

  @@map("usuarios")
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  telefone  String
  email     String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agendamentos Agendamento[]

  @@map("clientes")
}

model Servico {
  id         String   @id @default(cuid())
  nome       String
  descricao  String?
  preco      Float
  duracaoMin Int // Duração em minutos
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agendamentos Agendamento[]

  @@map("servicos")
}

model Agendamento {
  id          String            @id @default(cuid())
  dataHora    DateTime
  status      StatusAgendamento @default(AGENDADO)
  observacoes String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  usuarioId String
  clienteId String
  servicoId String

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  servico Servico @relation(fields: [servicoId], references: [id], onDelete: Restrict)

  @@index([usuarioId])
  @@index([clienteId])
  @@index([servicoId])
  @@index([dataHora])
  @@map("agendamentos")
}

model Configuracao {
  id           String   @id @default(cuid())
  usuarioId    String   @unique
  horarioInicio String  @default("08:00")
  horarioFim   String   @default("20:00")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("configuracoes")
}

model TokenRecuperacao {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiraEm  DateTime
  usado     Boolean  @default(false)
  ip        String?
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([usuarioId])
  @@index([ip])
  @@index([createdAt])
  @@map("tokens_recuperacao")
}

model CodigoVerificacao {
  id        String   @id @default(cuid())
  email     String
  codigo    String
  nome      String
  senhaHash String
  expiraEm  DateTime
  tentativas Int    @default(0)
  ip        String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([codigo])
  @@index([expiraEm])
  @@index([createdAt])
  @@map("codigos_verificacao")
}

model TentativaLogin {
  id          String   @id @default(cuid())
  email       String
  ip          String?
  tentativas  Int      @default(0)
  bloqueadoAte DateTime?
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([ip])
  @@index([createdAt])
  @@map("tentativas_login")
}
